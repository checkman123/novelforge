{
  "manifest_version": 3,
  "name": "NovelForge — Web Novel to EPUB",
  "version": "0.1.2",
  "description": "Download chapters from supported web-novel sites and build a clean EPUB, entirely in your browser.",
  "minimum_chrome_version": "109",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/ui/popup/index.html",
    "default_title": "NovelForge"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://ranobes.top/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "downloads", "offscreen", "alarms"],
  "host_permissions": ["*://ranobes.top/*"]
}
